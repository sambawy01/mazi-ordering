{
  "name": "foodics-ordering-backend",
  "version": "1.0.0",
  "description": "Backend middleware for Foodics ordering app (waiter + customer)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
