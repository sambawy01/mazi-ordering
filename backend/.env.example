# --- Foodics API ---
FOODICS_BASE_URL=https://api-sandbox.foodics.com/v5
FOODICS_CLIENT_ID=
FOODICS_CLIENT_SECRET=
FOODICS_REDIRECT_URI=https://yourapp.com/callback
FOODICS_BRANCH_ID=
# Optional: set access token directly for dev/testing (bypasses OAuth)
FOODICS_ACCESS_TOKEN=
# Secret used to verify Foodics webhook signatures (HMAC-SHA256)
FOODICS_WEBHOOK_SECRET=

# --- Backend ---
BACKEND_PORT=3000
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=
DB_PATH=./data/foodics.db
# Comma-separated list of allowed CORS origins in production
CORS_ORIGINS=https://mazi-ordering.vercel.app,https://*.vercel.app

# --- App ---
APP_NAME=MAZI Ordering
DEFAULT_CURRENCY=EGP

# --- Logging ---
LOG_LEVEL=info

# --- Twilio (SMS OTP for guest phone verification) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Paymob (Payment gateway) ---
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_INSTAPAY=
PAYMOB_INTEGRATION_ID_APPLE_PAY=
PAYMOB_IFRAME_ID=
# REQUIRED in production: HMAC secret for webhook verification
PAYMOB_WEBHOOK_HMAC_SECRET=
