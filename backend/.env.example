# --- Foodics API ---
FOODICS_BASE_URL=https://api-sandbox.foodics.com/v5
FOODICS_CLIENT_ID=
FOODICS_CLIENT_SECRET=
FOODICS_REDIRECT_URI=https://yourapp.com/callback
FOODICS_BRANCH_ID=
# Optional: set access token directly for dev/testing (bypasses OAuth)
FOODICS_ACCESS_TOKEN=

# --- Backend ---
BACKEND_PORT=3000
JWT_SECRET=
DB_PATH=./data/foodics.db

# --- App ---
APP_NAME=Foodics Ordering
DEFAULT_CURRENCY=SAR

# --- Logging ---
LOG_LEVEL=info

# --- Twilio (SMS OTP for guest phone verification) ---
# Get these from https://console.twilio.com
# Create a Verify Service at https://console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
